NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://jazor:jazor@localhost:5432/jazor?schema=public"

JWT_SECRET="change-me-in-production-please"
JWT_EXPIRES_IN="7d"

CORS_ORIGIN="http://localhost:5173"
APP_URL="http://localhost:5173"

# Mail via Resend (https://resend.com) — HTTP API, no SMTP port needed.
# MAIL_FROM must be on a verified domain; sandbox uses onboarding@resend.dev.
RESEND_API_KEY="re_xxxxxxxx"
MAIL_FROM="Jazor <no-reply@jazor.test>"

# Shipping charge (paise). Customer pays FLAT_SHIPPING_PAISE, free when the
# post-discount subtotal reaches FREE_SHIPPING_THRESHOLD_PAISE (0 = no auto-free,
# then shipping is free only via a FREE_SHIPPING promotion). Live courier rates
# are used for serviceability + delivery ETA only, never for the customer charge.
FLAT_SHIPPING_PAISE=9900
FREE_SHIPPING_THRESHOLD_PAISE=259900
